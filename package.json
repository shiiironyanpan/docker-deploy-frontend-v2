    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.24",
    "happy-dom": "^20.7.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
